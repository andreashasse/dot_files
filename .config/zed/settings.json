// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "remove_trailing_whitespace_on_save": true,
  "agent_servers": {
    "opencode": {
      "favorite_models": [
        "github-copilot/claude-sonnet-4.6/high"
      ],
      "default_model": "github-copilot/claude-sonnet-4.6/high",
      "favorite_config_option_values": {
        "model": [
          "github-copilot/claude-sonnet-4.6/high"
        ]
      },
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 100
  },
  "outline_panel": {
    "dock": "right"
  },
  "show_whitespaces": "all",
  "show_signature_help_after_edits": true,
  "tab_bar": {
    "show": true
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null
    },
    "enabled_in_text_threads": false
  },
  "vim_mode": true,
  "agent": {
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.5",
        "enable_thinking": true
      }
    ],
    "dock": "right",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5"
    },
  },
  "ui_font_size": 15,
  "buffer_font_size": 13,
  "theme": {
    "mode": "system",
    "light": "Gruvbox Dark Hard",
    "dark": "Gruvbox Dark Soft"
  },
  "buffer_font_features": {
    // Disable ligatures:
    "calt": false
  },
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "tabs": {
    // Show git status colors in the editor tabs.
    "git_status": true
  },
  "formatter": "language_server",
  "autosave": "on_focus_change",
  "languages": {
    "Erlang": {
      "language_servers": [
        "elp",
        "!erlang-ls"
      ]
    },
    "Elixir": {
      "language_servers": [
        "expert",
        "!elixir-ls",
        "!next-ls",
        "!lexical",
        "..."
      ]
    },
    "HEEx": {
      "language_servers": [
        "expert",
        "!elixir-ls",
        "!next-ls",
        "!lexical",
        "..."
      ]
    }
  },
  "indent_guides": {
    "background_coloring": "disabled",
    "active_line_width": 3,
    "line_width": 2,
    "enabled": true,
    "coloring": "indent_aware"
  },
  "experimental.theme_overrides": {
    "editor.document_highlight.bracket_background": "#884400"
  },
  "bindings": [
    {
      "context": "VimControl && vim_mode == normal",
      "bindings": {
        "ctrl-s": "vim::SearchUnderCursor"
      }
    }
  ]
}
